{
    "name": "englify",
    "version": "1.0.0",
    "description": "",
    "scripts": {
        "web:dev": "pnpm --filter @en/web dev",
        "web:build": "pnpm --filter @en/web build",
        "ai:dev": "pnpm --filter @en/server start:dev ai",
        "server:dev": "pnpm --filter @en/server start:dev",
        "server:generate": "pnpm --filter @en/server run prisma:generate",
        "server:postinstall": "pnpm --filter @en/server run postinstall",
        "dev": "concurrently \"pnpm web:dev\" \"pnpm ai:dev\" \"pnpm server:dev\"",
        "web:lint": "pnpm --filter @en/web lint",
        "server:lint": "pnpm --filter @en/server lint",
        "lint": "pnpm web:lint && pnpm server:lint"
    },
    "dependencies": {
        "@nestjs/mapped-types": "*",
        "dayjs": "^1.11.19",
        "md5": "^2.3.0"
    },
    "devDependencies": {
        "@types/md5": "^2.3.6",
        "concurrently": "^9.2.1",
        "eslint-plugin-oxlint": "^1.53.0",
        "oxfmt": "^0.38.0",
        "oxlint": "^1.53.0"
    },
    "packageManager": "pnpm@10.32.1"
}
